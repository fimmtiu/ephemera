<!DOCTYPE html>
<html>
  <head>
    <title>Ephemera</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <nav class="main-nav">
        <div class="nav-brand">Ephemera</div>
        <div class="nav-links">
          <%= link_to "Pictures", pictures_path, class: "nav-link" %>
          <%= link_to "Profile", mastodon_profile_path, class: "nav-link" %>
          <%= link_to "Followers", followers_path, class: "nav-link" %>
          <%= link_to "Logs", logs_path, class: "nav-link" %>
          <%= button_to "Logout", session_path, method: :delete, class: "nav-link logout-btn" %>
        </div>
      </nav>
    <% end %>

    <main class="container">
      <% if notice.present? %>
        <div class="notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="alert"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
