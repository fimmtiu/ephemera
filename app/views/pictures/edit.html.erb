<h1>Edit Picture</h1>

<div class="picture-preview">
  <%= image_tag @image_url, alt: @picture.alt_text.presence || @picture.original_filename %>
</div>

<div class="picture-actions">
  <%= link_to "Download", @download_url, download: @picture.original_filename, class: "btn" %>
  <button type="button" class="btn" onclick="document.getElementById('replace-dialog').showModal()">Replace</button>
</div>

<dialog id="replace-dialog">
  <h2>Replace Image</h2>
  <%= form_with url: replace_picture_path(@picture), method: :patch, multipart: true do |f| %>
    <div class="form-group">
      <%= f.file_field :file, accept: "image/*", name: "picture[file]" %>
    </div>
    <div class="dialog-actions">
      <button type="button" class="btn" onclick="document.getElementById('replace-dialog').close()">Cancel</button>
      <%= f.submit "Replace", class: "btn" %>
    </div>
  <% end %>
</dialog>

<%= form_with model: @picture do |f| %>
  <div class="form-group">
    <%= f.label :alt_text %>
    <%= f.text_area :alt_text, rows: 3 %>
  </div>

  <div class="form-group">
    <%= f.label :hashtags %>
    <%= f.text_field :hashtags, placeholder: "#photography #landscape" %>
  </div>

  <div class="form-group">
    <%= f.label :sensitive_content, "Sensitive content warning" %>
    <%= f.text_field :sensitive_content, placeholder: "Leave blank if not sensitive" %>
  </div>

  <div class="form-group">
    <%= f.label :order, "Position in queue" %>
    <%= f.number_field :order, min: 1, max: Picture.count %>
  </div>

  <%= f.submit "Save", class: "btn" %>
  <%= f.submit "Save and next", class: "btn" %>
<% end %>

<%= link_to "Back", pictures_path, class: "btn btn-back" %>
