<h1><%= @picture.original_filename || @picture.s3_key %></h1>

<dl>
  <dt>Order</dt>
  <dd><%= @picture.order %></dd>

  <dt>Alt Text</dt>
  <dd><%= @picture.alt_text || "—" %></dd>

  <dt>Hashtags</dt>
  <dd><%= @picture.hashtags || "—" %></dd>

  <dt>Sensitive Content</dt>
  <dd><%= @picture.sensitive_content.present? ? @picture.sensitive_content : "No" %></dd>

  <dt>Content Type</dt>
  <dd><%= @picture.content_type %></dd>

  <dt>S3 Key</dt>
  <dd><%= @picture.s3_key %></dd>
</dl>

<%= link_to "Edit", edit_picture_path(@picture), class: "btn" %>
<%= link_to "Back", pictures_path, class: "btn" %>
